<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HakPlace" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>


    <style name="Theme.HakPlace" parent="Base.Theme.HakPlace" />

    <!-- 구글 MaterialDatePicker용 테마 -->
    <style name="CustomMaterialCalendar" parent="ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="elevationOverlayEnabled">false</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
    </style>

    <!-- 기본 DatePickerDialog용 초록색 테마 -->
    <style name="GreenDatePickerTheme" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">@color/primary</item>
    </style>

    <!-- 컴팩트한 정렬 메뉴 전용 테마 -->
    <style name="SortPopupMenuStyle" parent="Widget.Material3.PopupMenu">

        <!-- 핵심 -->
        <item name="android:popupBackground">@drawable/popup_bg</item>

        <!-- Material3 tint 제거 -->
        <item name="colorSurface">@android:color/white</item>
        <item name="colorSurfaceContainer">@android:color/white</item>
        <item name="colorSurfaceContainerHigh">@android:color/white</item>

        <!-- 보라 overlay 제거 -->
        <item name="elevationOverlayEnabled">false</item>

    </style>
</resources>